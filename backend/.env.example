# Copy this file to .env and fill in your keys
# cp .env.example .env

# Required — Gemini API (content + quiz generation)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Required — Pexels API (story player images, free)
# Get key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional — OpenAI API (higher-quality TTS narration)
# Falls back to browser TTS if not set or billing inactive
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required — change this to a long random string in production
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret-in-production
